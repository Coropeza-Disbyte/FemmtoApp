APP_PATH=./apps/app-debug.apk
APP_PACKAGE=com.example.app
APP_ACTIVITY=com.example.app.MainActivity
DEVICE_NAME=emulator-5554
PLATFORM_VERSION=17

# Versión del APK bajo test — activa version gating en specs
APP_VERSION=

# Ruta local de Google Drive donde el dev sube los APKs
# El watcher (npm run watch:apk) monitorea esta carpeta automáticamente
DRIVE_APK_PATH=G:\Mi unidad\Femmto APKs
RN_REPO_PATH=C:\ruta\al\repo\react-native

# Servidor Appium remoto (dejar vacío para usar Appium local)
# Opciones: IP pública de la oficina, DuckDNS hostname, o IP de red local
# Ejemplo: APPIUM_HOST=tuequipo.duckdns.org   APPIUM_PORT=4723
APPIUM_HOST=
APPIUM_PORT=4723

# Puerto del monitor QA en tiempo real
MONITOR_PORT=3001

# Credenciales de prueba — completar con cuenta QA dedicada, nunca cuenta personal ni de producción
TEST_USER_EMAIL=qa@tudominio.com
TEST_USER_PASSWORD=tu_password_de_prueba
